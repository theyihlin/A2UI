{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a2ui.org/renderers/lit/catalogs/v1/a2ui-lit-web-catalog.json",
  "title": "A2UI Lit Web Catalog",
  "description": "Composed catalog of standard primitives and dynamic components for Lit.",
  "catalogId": "https://a2ui.org/renderers/lit/catalogs/v1/a2ui-lit-web-catalog.json",
  "components": {
    "Text": {
      "type": "object",
      "properties": {
        "component": { "const": "Text" },
        "text": { "type": "string" },
        "variant": { "type": "string", "enum": ["h1", "h2", "h3", "body", "caption"] }
      },
      "required": ["component", "text"]
    },
    "Button": {
      "type": "object",
      "properties": {
        "component": { "const": "Button" },
        "child": { "type": "string" },
        "action": { "type": "object" }
      },
      "required": ["component", "child", "action"]
    },
    "LocalWidget": {
      "type": "object",
      "properties": {
        "component": { "const": "LocalWidget" }
      },
      "required": ["component"],
      "x-a2ui-component": {
        "uri": "http://localhost:8000/components/a2ui-local-widget.js",
        "sri": "sha384-zSvbnlp7FOJZzrD4td51PoNk1H2Q8tagFTFdw02Ytu8Ym5u6xMl0lcZtZIxuXYMY"
      }
    },
    "McpApp": {
      "type": "object",
      "properties": {
        "component": { "const": "McpApp" },
        "resourceUri": { "type": "string" },
        "htmlContent": { "type": "string" },
        "height": { "type": "number" },
        "allowedTools": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["component"],
      "x-a2ui-component": {
        "uri": "http://localhost:8000/web/components/v1/a2ui-web-mcp-app/a2ui-web-mcp-app.js",
        "sri": "sha384-XE9IcQtnmN06CkimVKe5+X4Vz5La1qP+gMeH6vu44Ixwecv3YHqCKTfmtl6jqzPE"
      }
    }
  }
}
